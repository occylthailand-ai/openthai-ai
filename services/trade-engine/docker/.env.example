# คัดลอกเป็น .env แล้วใส่ค่าจริง:  cp .env.example .env
# หมายเหตุ: ไฟล์ .env ถูก gitignore — อย่า commit คีย์จริง

# ── Datastore passwords ───────────────────────────────────────────────
POSTGRES_PASSWORD=ChangeThisStrongPassword123!
NEO4J_PASSWORD=ChangeThisStrongNeo4jPass456!

# ── Trade-data platform API keys (ใส่คีย์จริงตอนใช้งาน) ────────────────
TRADEINT_API_KEY=
VOLZA_API_KEY=
TENDATA_API_KEY=
ROCKETREACH_API_KEY=
IMPORTGENIUS_API_KEY=

# ── LLM ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# ── Service connections (default ตรงกับ docker-compose) ───────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=trade_entities

# ── App / security ────────────────────────────────────────────────────
OTAI_ENV=development
OTAI_VERSION=14.2.0
# คีย์สำหรับ header X-API-Key — เปลี่ยนก่อนขึ้น production
API_KEY=otai_v14_change_me
# RATE_LIMIT_PER_MIN ปล่อยว่างเพื่อใช้ default (dev=10, prod=100)
RATE_LIMIT_PER_MIN=
