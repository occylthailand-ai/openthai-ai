# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OpenThai.ai AI Engine - Environment Configuration
# เครื่องมือ AI OpenThai.ai - การตั้งค่า Environment
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Copy this file to .env and fill in your values
# คัดลอกไฟล์นี้เป็น .env และใส่ค่าของคุณ

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI & API Keys | AI และ API Keys
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Anthropic Claude API Key (required | จำเป็น)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Internal API Key (for client authentication)
# คีย์ API ภายใน (สำหรับยืนยันตัวตน client)
API_KEY=openthai_dev_key_change_in_production

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database | ฐานข้อมูล
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=openthai_ai
POSTGRES_USER=openthai_admin
POSTGRES_PASSWORD=change_this_to_secure_password_2026

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Vector Database (Qdrant) | ฐานข้อมูลเวกเตอร์
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=openthai-knowledge
QDRANT_DIMENSION=1536

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Redis (Caching) | Redis (แคช)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

REDIS_HOST=redis
REDIS_PORT=6379
CACHE_TTL=3600

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Service URLs | URL บริการ
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

RAG_SERVICE_URL=http://rag-service:8000
MCP_SERVICE_URL=http://mcp-server:8000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Application Settings | การตั้งค่าแอปพลิเคชัน
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# AI Settings
DEFAULT_MODEL=claude-sonnet-4-20250514
MAX_CONTEXT_ENTRIES=10
MAX_TOKENS=2000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Future: Claude Mythos Integration | อนาคต: เชื่อม Claude Mythos
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# When Claude Mythos API becomes available
# เมื่อ Claude Mythos API พร้อมใช้งาน
# CLAUDE_MYTHOS_API_KEY=
# CLAUDE_MYTHOS_ENDPOINT=
