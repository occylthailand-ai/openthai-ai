# ─────────────────────────────────────────────────────────────────────────────
# OpenThai AI — Environment Variables Schema
# ทุกตัวแปรที่ระบุ REQUIRED=true ต้องมีค่าก่อน deploy production
# ─────────────────────────────────────────────────────────────────────────────

[ANTHROPIC_API_KEY]
required=true
description=Claude AI API Key จาก console.anthropic.com
format=sk-ant-*
rotation=90days

[GEMINI_API_KEY]
required=false
description=Gemini fallback API Key จาก aistudio.google.com
format=AIza*
rotation=90days

[JWT_SECRET]
required=true
description=Random 32-byte hex สำหรับ sign JWT tokens
format=hex64chars
rotation=180days
generate=node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

[SUPABASE_URL]
required=true
description=Supabase project URL
format=https://*.supabase.co

[SUPABASE_ANON_KEY]
required=true
description=Supabase public anon key (safe to expose in frontend)
format=sb_publishable_*

[SUPABASE_SERVICE_KEY]
required=true
description=Supabase service role key — ห้าม expose ใน frontend เด็ดขาด
format=sb_secret_*
rotation=180days

[SMTP_USER]
required=true
description=Gmail สำหรับส่งอีเมล
format=*@gmail.com

[SMTP_PASS]
required=true
description=Gmail App Password (ไม่ใช่ password ปกติ)
format=xxxx xxxx xxxx xxxx
rotation=365days

[ADMIN_KEY]
required=true
description=Secret key สำหรับเข้า admin panel
rotation=90days

[FRONTEND_URL]
required=true
description=URL ของ frontend (ใช้ CORS whitelist)
format=https://*.openthai-ai.com

[PORT]
required=false
default=8000
description=Backend server port
