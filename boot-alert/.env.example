# ===== Boot Alert config — คัดลอกเป็น .env แล้วเติมค่า =====

# เบอร์ที่จะรับ SMS (คั่นด้วย comma) — ใส่เป็นเบอร์ไทย 0xxxxxxxxx ได้เลย
ALERT_NUMBERS=0972560801,0658714008

# ผู้ให้บริการ SMS: thsms | smsmkt | custom
SMS_PROVIDER=thsms

# ชื่อผู้ส่ง (Sender name) ที่ลงทะเบียนไว้กับผู้ให้บริการ
SMS_SENDER=Openthai

# --- ถ้าใช้ THSMS (thsms.com) ---
# 1) เอา API key จาก dashboard (เมนู API/Settings)
# 2) SMS_SENDER ต้องเป็นชื่อผู้ส่งที่ "อนุมัติแล้ว" ในบัญชี ไม่งั้น THSMS จะปฏิเสธ
# 3) ถ้า dashboard ระบุ endpoint อื่น ให้ใส่ทับที่ THSMS_API_URL
THSMS_API_KEY=
# THSMS_API_URL=https://thsms.com/api/rest

# --- ถ้าใช้ SMSMKT (smsmkt.com) ---
SMSMKT_API_KEY=
SMSMKT_SECRET_KEY=

# --- ถ้าใช้ custom gateway (ตั้งค่าได้ทุกอย่าง) ---
# SMS_PROVIDER=custom
# SMS_URL=https://your-gateway/api/send
# SMS_METHOD=POST
# SMS_HEADERS={"Authorization":"Bearer xxx","Content-Type":"application/json"}
# SMS_BODY={"to":"{to}","message":"{message}","sender":"{sender}"}

# ส่งสัญญาณ "ยังออนไลน์" ทุกกี่ชั่วโมง (0 = ปิด, ใช้แค่แจ้งตอนบูต)
HEARTBEAT_HOURS=0
