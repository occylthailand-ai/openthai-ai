# ===== Boot Alert config — คัดลอกเป็น .env แล้วเติมค่า =====

# ช่องทางแจ้งเตือน — ใส่หลายอันพร้อมกันได้ คั่นด้วย comma
# ตัวเลือก: telegram | thsms | smsmkt | custom
# ตัวอย่าง "ทั้ง Telegram และ SMS":  CHANNELS=telegram,thsms
CHANNELS=telegram,thsms

# ───────── Telegram (ฟรี เด้งเข้าแอปทันที) ─────────
# 1) เปิด Telegram ทักบอท @BotFather → /newbot → ได้ TOKEN
# 2) ทักบอทที่เพิ่งสร้าง พิมพ์ /start
# 3) รัน:  node notify.js --tg-chatid   → จะได้ chat_id มาใส่ด้านล่าง
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
# TELEGRAM_API_BASE=https://api.telegram.org   # เปลี่ยนได้ถ้าใช้ proxy

# ───────── SMS (thsms/smsmkt/custom) ─────────
# เบอร์ที่จะรับ SMS (คั่นด้วย comma) — เบอร์ไทย 0xxxxxxxxx ได้เลย
ALERT_NUMBERS=0972560801,0658714008
# ชื่อผู้ส่ง (Sender name) ที่ลงทะเบียน/อนุมัติไว้กับผู้ให้บริการ
SMS_SENDER=Openthai

# --- ถ้าใช้ THSMS (thsms.com) ---
# 1) เอา API key จาก dashboard (เมนู API/Settings)
# 2) SMS_SENDER ต้องเป็นชื่อผู้ส่งที่ "อนุมัติแล้ว" ในบัญชี ไม่งั้น THSMS จะปฏิเสธ
# 3) ถ้า dashboard ระบุ endpoint อื่น ให้ใส่ทับที่ THSMS_API_URL
THSMS_API_KEY=
# THSMS_API_URL=https://thsms.com/api/rest

# --- ถ้าใช้ SMSMKT (smsmkt.com) ---
SMSMKT_API_KEY=
SMSMKT_SECRET_KEY=

# --- ถ้าใช้ custom gateway (ตั้งค่าได้ทุกอย่าง) ---
# CHANNELS=custom
# SMS_URL=https://your-gateway/api/send
# SMS_METHOD=POST
# SMS_HEADERS={"Authorization":"Bearer xxx","Content-Type":"application/json"}
# SMS_BODY={"to":"{to}","message":"{message}","sender":"{sender}"}

# ส่งสัญญาณ "ยังออนไลน์" ทุกกี่ชั่วโมง (0 = ปิด, ใช้แค่แจ้งตอนบูต)
HEARTBEAT_HOURS=0
