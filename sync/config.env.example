# ───────────────────────────────────────────────────────────────
# sync/config.env — OpenThaiAi Auto-Sync Configuration
# คัดลอกไฟล์นี้เป็น config.env แล้วแก้ค่าให้ถูกต้อง
# ───────────────────────────────────────────────────────────────

# ── Git Settings ─────────────────────────────────────────────
GIT_REPO_DIR="/path/to/openthai-ai"
GIT_BRANCH="claude/pending-tasks-kcx852"
GIT_REMOTE="origin"

# ── Vercel Deploy Hook (Mobile Sync) ─────────────────────────
# สร้างได้ที่: Vercel Dashboard → Project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK_URL=""
VERCEL_PROJECT_NAME="openthai-ai"

# ── Google Drive (Drive Sync) ─────────────────────────────────
# Google Drive Folder ID ที่เห็นใน URL เช่น .../folders/1YgSg...
GDRIVE_FOLDER_ID="1YgSgwC6rcSvwryhCfCK4gjwqHHKd9Cpp"
# Service Account JSON path (ถ้าใช้ service account)
GOOGLE_SERVICE_ACCOUNT_JSON=""
# หรือใช้ OAuth token (ถ้าใช้ OAuth)
GOOGLE_OAUTH_TOKEN=""

# ── OneDrive (OneDrive Sync via rclone) ───────────────────────
# ติดตั้ง rclone: https://rclone.org/install/
# ตั้งค่า: rclone config → ใส่ชื่อ remote ว่า "onedrive"
RCLONE_ONEDRIVE_REMOTE="onedrive"
ONEDRIVE_TARGET_PATH="OpenThaiAi/code-backup"

# ── Slack Notifications ────────────────────────────────────────
# แจ้งเตือน Slack เมื่อซิ้งสำเร็จ (optional)
SLACK_WEBHOOK_URL=""

# ── Sync Schedule ─────────────────────────────────────────────
# ความถี่ในการซิ้งอัตโนมัติ (cron format)
# ทุก 6 ชั่วโมง: "0 */6 * * *"
# ทุกวัน 3 ทุ่ม: "0 21 * * *"
SYNC_CRON_SCHEDULE="0 */6 * * *"
