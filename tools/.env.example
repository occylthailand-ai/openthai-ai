# ─── Openthai.ai Social Tools — ตัวอย่าง .env ───────────────────────────────
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# cp .env.example .env

# ─── Facebook ─────────────────────────────────────────────────────────────────
# Access Token จาก https://developers.facebook.com/tools/explorer/
# สิทธิ์ที่ต้องการ: public_profile, pages_read_engagement, instagram_basic
FB_ACCESS_TOKEN=EAAxxxxxxxxxxxxx

# App credentials (ถ้าต้องการสร้าง token ด้วย app)
FB_APP_ID=123456789
FB_APP_SECRET=abc123def456

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx

# OpenAI (optional fallback)
OPENAI_API_KEY=sk-proj-xxxxxxxxxx

# Google Gemini (optional fallback)
GEMINI_API_KEY=AIzaSyxxxxxxxxxx

# ─── Chrome / Browser ─────────────────────────────────────────────────────────
# กำหนด path Chrome ถ้าไม่อยู่ใน default locations
# CHROME_PATH=/usr/bin/google-chrome
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# ─── Output ───────────────────────────────────────────────────────────────────
# โฟลเดอร์บันทึกผลลัพธ์ (default: ./output)
# OUTPUT_DIR=/home/user/social-output

# ─── Chat / Notification Upload ───────────────────────────────────────────────
# Slack Webhook สำหรับอัพโหลด screenshot/รายงาน
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# LINE Notify Token — https://notify-bot.line.me/
# LINE_NOTIFY_TOKEN=xxxxxxxxxxxxxx

# Generic chat webhook (Discord / custom)
# CHAT_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
