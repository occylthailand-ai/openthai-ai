# ─── Google Gemini API (ฟรี 100%) ───────────────────────────────────────────
# รับ key ฟรีได้ที่ https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxx

# Backend port (optional, default 8000)
PORT=8000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# When the SPA is on another host (e.g. Vercel) build the frontend with:
# VITE_API_URL=https://your-backend-host.example.com
# so all /api calls go to this Express server (see frontend/src/apiBase.js).

# Production: set to your live site (Google OAuth redirect back + CORS)
# FRONTEND_URL=https://www.openthai-ai.com

# Google OAuth — Authorized redirect URI in Google Cloud Console must match:
# GOOGLE_REDIRECT_URI=https://YOUR-API-HOST/api/auth/google/callback

# ANTHROPIC_API_KEY=
# LINE_CHANNEL_TOKEN=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# JWT_SECRET=

# ─── Production hardening (fail-closed) ──────────────────────────────────────
# ในโหมด production (NODE_ENV=production หรือบน Vercel) "ต้อง" ตั้งค่าด้านล่าง
# มิฉะนั้นช่องทางนั้นจะถูกปิด (ไม่ fallback ค่า default สาธารณะอีกต่อไป)
# ADMIN_USERS=admin:$2a$12$<bcrypt-hash>          # หรือใช้ ADMIN_PASSWORD_PLAIN
# ADMIN_PASSWORD_PLAIN=
# ADMIN_KEY=                                       # คีย์ป้องกัน endpoint admin
# ADMIN_OVERRIDE_KEY=                              # คีย์ login ฉุกเฉิน
# N8N_WEBHOOK_SECRET=                              # ไม่ตั้ง = ปิด /api/n8n/trigger
# OMISE_WEBHOOK_SECRET=                            # ไม่ตั้ง = ปฏิเสธ webhook ทุกอัน
# GOOGLE_ALLOWED_EMAILS=you@example.com            # ไม่ตั้ง = ปิด Google OAuth login
# CORS_ORIGINS=https://www.openthai-ai.com         # โดเมนเพิ่มเติมที่อนุญาต (คั่นด้วย ,)

# ─── Durable storage (กันข้อมูลหายบน serverless /tmp) ────────────────────────
# ตั้งคู่นี้เพื่อให้ payments/entitlements (และ inventory/credits) ถูกเก็บถาวรใน Supabase
# รัน SQL: backend/migrations/005_kv_store.sql + 000-all-in-one.sql ก่อน
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_KEY=

# นโยบายระบบถาวร (ไม่ใช้ env) — แก้ที่ backend/data/system_charter.json + GET /api/system/charter
