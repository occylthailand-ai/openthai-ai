# ══════════════════════════════════════════════════════════════════════════════
# Openthai.ai — Backend Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าให้ครบก่อนรัน
# ══════════════════════════════════════════════════════════════════════════════

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# Google Gemini (ฟรี — แนะนำสำหรับเริ่มต้น) https://aistudio.google.com
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxx

# Anthropic Claude (ทางเลือก) https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# OpenRouter (รองรับหลาย model) https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8000
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://www.openthai-ai.com

# URL หลักของเว็บ (ใช้ในอีเมล / ลิงก์ Affiliate / Admin links)
DOMAIN_URL=https://www.openthai-ai.com
# อีเมลของร้านค้า Openthai (ใช้เป็น producer_email สำหรับออเดอร์ first-party)
STORE_PRODUCER_EMAIL=store@openthai-ai.com

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
# สุ่มสตริงยาว ≥ 32 ตัวอักษร
JWT_SECRET=change-me-to-a-long-random-secret-string

# Admin panel password (ถ้าไม่ set บน Vercel จะปฏิเสธทุก admin request)
ADMIN_KEY=change-me-admin-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD_PLAIN=change-me-admin-password
ADMIN_OVERRIDE_KEY=change-me-override-key
# Recovery codes คั่นด้วย comma: RECOVERY_CODES=CODE1,CODE2,CODE3
RECOVERY_CODES=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# สร้างที่ https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://YOUR-API-HOST/api/auth/google/callback
# อีเมลที่อนุญาตให้ login (คั่นด้วย comma; เว้นว่าง = อนุญาตทุก Gmail)
GOOGLE_ALLOWED_EMAILS=

# ─── Payment — Omise ──────────────────────────────────────────────────────────
# สร้าง account ที่ https://omise.co → Dashboard → Keys
OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxx
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxx
# Plan IDs — สร้างใน Omise Dashboard → Subscriptions → Plans แล้วนำ ID มาใส่
OMISE_PLAN_PRO=plan_xxxxxxxxxxxxxxxx
OMISE_PLAN_PREMIER=plan_xxxxxxxxxxxxxxxx
# Webhook secret — ตั้งใน Omise Dashboard → Webhooks
OMISE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ─── Database — Supabase ──────────────────────────────────────────────────────
# https://supabase.com → Project Settings → API
# ถ้าไม่ set จะ fallback เป็น JSON file ใน backend/data/ (ข้อมูลหายเมื่อ restart)
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Gmail: ใช้ App Password (ไม่ใช่รหัส Gmail จริง) https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
ORDER_NOTIFY_EMAIL=your@gmail.com

# ─── LINE ─────────────────────────────────────────────────────────────────────
# https://developers.line.biz → Messaging API → Channel access token
LINE_CHANNEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_NOTIFY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Facebook / Instagram ────────────────────────────────────────────────────
# https://developers.facebook.com → Graph API → Page token
FB_PAGE_ID=000000000000000
FB_PAGE_TOKEN=EAAxxxxxxxxxxxxxxxx
IG_USER_ID=000000000000000

# ─── TikTok ──────────────────────────────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Voice / TTS — ElevenLabs ────────────────────────────────────────────────
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Voice ID — เลือกได้จาก https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── Video AI ────────────────────────────────────────────────────────────────
# RunwayML: https://runwayml.com → Account → API
RUNWAY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Pika Labs: https://pika.art
PIKA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Kling AI: https://klingai.com
KLING_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Luma Dream Machine: https://lumalabs.ai
LUMA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Automation — n8n ────────────────────────────────────────────────────────
N8N_URL=https://your-n8n-instance.example.com
N8N_WEBHOOK_SECRET=change-me-n8n-secret

# ─── Notifications — Slack ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/xxxxxxxxxxxxxxxx
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxx

# ─── Cron Jobs ────────────────────────────────────────────────────────────────
CRON_SECRET=change-me-cron-secret
BACKEND_URL=https://YOUR-API-HOST

# ─── Data Scripts Output ──────────────────────────────────────────────────────
# Path สำหรับสคริปต์ create_*.js (default: ./all-platform-files)
# OUTPUT_DIR=/path/to/output
