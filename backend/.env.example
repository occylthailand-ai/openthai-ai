# ─── Google Gemini API (ฟรี 100%) ───────────────────────────────────────────
# รับ key ฟรีได้ที่ https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxx

# Backend port (optional, default 8000)
PORT=8000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# When the SPA is on another host (e.g. Vercel) build the frontend with:
# VITE_API_URL=https://your-backend-host.example.com
# so all /api calls go to this Express server (see frontend/src/apiBase.js).

# Production: set to your live site (Google OAuth redirect back + CORS)
# FRONTEND_URL=https://www.OpenThaiAi.com

# Google OAuth — Authorized redirect URI in Google Cloud Console must match:
# GOOGLE_REDIRECT_URI=https://YOUR-API-HOST/api/auth/google/callback

# ANTHROPIC_API_KEY=
# LINE_CHANNEL_TOKEN=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# JWT_SECRET=

# นโยบายระบบถาวร (ไม่ใช้ env) — แก้ที่ backend/data/system_charter.json + GET /api/system/charter
