# ── OpenThai AI — Backend Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Claude / Anthropic API (Required) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=production

# ── Frontend CORS ─────────────────────────────────────────────────────────────
FRONTEND_URL=https://www.openthai-ai.com

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed)
# DATABASE_URL=sqlite+aiosqlite:///./openthai.db
# PostgreSQL (Railway add-on — recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Payment (PromptPay) ───────────────────────────────────────────────────────
# เบอร์โทร 10 หลัก หรือ เลขประจำตัวผู้เสียภาษี 13 หลัก
PROMPTPAY_ID=0812345678

# ── News Monitor ─────────────────────────────────────────────────────────────
# LINE Notify token — รับได้ที่ https://notify-bot.line.me/my/
LINE_NOTIFY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Email ที่รับ daily digest ทุก 08:00 น.
NEWS_DIGEST_EMAIL=your@email.com

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# ถ้าไม่ตั้งค่า → log ใน console แทน (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@openthai-ai.com

# ── Task Router — LINE Notify (แต่ละทีมสร้าง token ของตัวเองที่ notify-bot.line.me/my/) ──
LINE_NOTIFY_DEV=xxx_dev_team_token
LINE_NOTIFY_SALES=xxx_sales_team_token
LINE_NOTIFY_SUPPORT=xxx_support_team_token
LINE_NOTIFY_FINANCE=xxx_finance_team_token
LINE_NOTIFY_ALL=xxx_all_team_broadcast_token   # optional: urgent alerts

# ── Task Router — LINE OA Webhook ────────────────────────────────────────────
LINE_OA_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_OA_CHANNEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Task Router — GitHub Webhook ─────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=admin-secret-key-change-this
